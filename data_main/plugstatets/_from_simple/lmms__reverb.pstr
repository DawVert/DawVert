<plugstatetransform daw_out="lmms" plugtype="simple:reverb">
  <in__wet to="mix" type="float">0.5</in__wet>
  <replace plugtype="native:lmms:reverbsc" />
  <out__param to="size" only_value="1" type="float">0.5</out__param>
  <out__param to="color" only_value="1" type="float">7000</out__param>
  <out__wet from="mix" type="float">1</out__wet>
</plugstatetransform>